# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Virtual environments
.venv/
venv/

# Data (raw CSVs are large; download via scripts/download_data.sh)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
*.db
*.sqlite

# Models / artifacts
models/*
!models/.gitkeep
*.joblib
*.keras
*.h5

# Reports — keep the small EDA figures committed so the EDA report renders on GitHub
reports/figures/*
!reports/figures/.gitkeep
!reports/figures/*.png


# OS / IDE
.DS_Store
.idea/
.vscode/

# Testing
.pytest_cache/
.coverage

# Streamlit
.streamlit/secrets.toml
